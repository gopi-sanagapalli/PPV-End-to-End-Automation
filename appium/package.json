{
  "name": "appium",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "android": "wdio run config/wdio.android.conf.ts",
    "android:tv": "TV_TARGET=androidtv wdio run config/wdio.android.conf.ts --spec ./tests/android/tv.ppv.spec.ts",
    "tv:ppv:flows": "ts-node scripts/run-tv-ppv-flows.ts",
    "android:scenarios": "ts-node scripts/run-android-scenarios.ts",
    "selected:scenarios": "ts-node scripts/run-android-scenarios.ts",
    "ios": "wdio run config/wdio.ios.conf.ts",
    "android:debug": "wdio run config/wdio.android.conf.ts --logLevel debug",
    "ios:debug": "wdio run config/wdio.ios.conf.ts --logLevel debug",
    "test": "echo \"Run: npm run android  OR  npm run ios\""
  },
