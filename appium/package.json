  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@wdio/appium-service": "^9.28.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webdriverio": "^9.28.0"
  }
