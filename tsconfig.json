{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "pages/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "flows/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "configLoader.ts",
    "playwright.config.ts"
  ]
}