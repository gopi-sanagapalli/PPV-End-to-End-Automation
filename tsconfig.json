{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "pages/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "flows/**/*.ts",
    "tests/**/*.ts"
  ]
}