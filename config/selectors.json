{
  "schedule": {
    "buyCTA": "button:has-text('Buy'), button:has-text('Buy now')"
  },

  "ppv": {
    "pageTitle": "h1",
    "pageSubHeader": "h1 + p",

    "eventName": "h1:has-text('vs'), h2:has-text('vs')",

    "price": "[data-testid*='price'], text=/\\$\\d+/",

    "buyCTA": "button[type='submit']",

    "image": "img",

    "upsellCard": "section:has-text('Ultimate')",
    "upsellLabel": "text=/included/i",
    "upsellPlanName": "text=/Ultimate/i",
    "upsellPrice": "text=/\\$\\d+/",
    "upsellSubText": "text=/month|auto renew/i"
  },

  "daznPlan": {
    "pageTitle": "h1",
    "pageSubHeader": "h1 + p",

    "ctaContinue": "button[type='submit']",

    "trialCard": "section:has-text('free trial')",
    "trialTitle": "text=/free trial/i",
    "trialSelected": "[aria-checked='true']",

    "upsellCard": "section:has-text('annual')",
    "upsellPlanName": "text=/annual/i",
    "upsellPrice": "text=/\\$\\d+/",
    "upsellSubText": "text=/month/i"
  },

  "signup": {
    "email": "input[type='email']",
    "firstName": "input[name='firstName']",
    "lastName": "input[name='lastName']",
    "password": "input[type='password']",
    "continueButtonStep2": "button[type='submit']"
  },

  "payment": {
    "pageTitle": "h1",

    "header": "h1 + p",

    "tier": "[data-testid*='plan'], text=/standard|ultimate/i",

    "changeCTA": "button:has-text('Change')",

    "ppvName": "text=/vs\\.?/i",

    "priceAll": "text=/\\$\\d+/",

    "freeTrial": "text=/free/i",

    "todayText": "text=/Today you pay/i",

    "todayPrice": "[data-test-id*='total'], text=/\\$\\d+/",

    "nextPayment": "text=/Next payment/i",

    "cancellation": "text=/cancel/i"
  }
}