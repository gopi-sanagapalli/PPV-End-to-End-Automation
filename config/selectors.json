{
  "cookies": {
    "acceptButton": "#onetrust-accept-btn-handler",
    "rejectButton": "#onetrust-reject-all-handler"
  },

  "landing": {
    "container": "section, article",

    "eventName": "h2, h3",
    "date": "text=/\\b(AM|PM)\\b/i",

    "buyCTA": "button:has-text('Buy'), button:has-text('Buy now')"
  },

  "ppv": {
    "main": "main",

    "pageTitle": "h1",

    "eventName": "h1",
    "date": "text=/\\b(AM|PM)\\b/i",

    "buyCTA": "button:has-text('Continue'), button:has-text('Buy')",

    "price": "text=/\\$\\d+(\\.\\d{2})?/",

    "image": "img",

    "upsellSection": "section:has-text('DAZN Ultimate')",
    "upsellLabel": "text=/Pay-per-views included/i",
    "upsellPlan": "text=/DAZN Ultimate/i",

    "bundleCard": "section:has-text('Bundle')",
    "bundleDiscount": "text=/save/i",
    "bundleSecondEvent": "text=/vs\\.?/i"
  },

  "daznPlan": {
    "pageTitle": "h1",
    "pageSubHeader": "h1 + p",

    "ctaContinue": "button:has-text('Continue')",

    "trialCard": "section:has-text('free trial')",
    "trialTitle": "text=/free trial/i",
    "trialDescription": "text=/Cancel anytime/i",
    "trialSelected": "[aria-checked='true']",

    "upsellCard": "section:has-text('annual'), section:has-text('pay over time')",
    "upsellPlanName": "text=/annual/i",

    "upsellPrice": "text=/\\$\\d+(\\.\\d{2})?/",
    "upsellSubText": "text=/month/i",
    "upsellRenewal": "text=/auto renew/i",

    "upsellFeature1": "li:nth-child(1)",
    "upsellFeature2": "li:nth-child(2)",
    "upsellFeature3": "li:nth-child(3)"
  },

  "payment": {
    "pageTitle": "h1",
    "header": "text=/payment/i",
    "tier": "text=/DAZN/i",

    "changeCTA": "button:has-text('Change')",

    "ppvName": "text=/vs\\.?/i",
    "priceAll": "text=/\\$\\d+(\\.\\d{2})?/",

    "freeTrial": "text=/free/i",

    "todayText": "text=/Today you pay/i",
    "todayPrice": "[data-test-id='summary_total_value']",

    "nextPayment": "text=/Next payment/i",
    "cancellation": "text=/cancel/i"
  },

  "signup": {
    "email": "input[type='email']",
    "firstName": "input[name='firstName']",
    "lastName": "input[name='lastName']",
    "password": "input[type='password']",
    "continueButtonStep2": "button[type='submit']"
  },

  "schedule": {
    "buyCTA": "button:has-text('Buy'), button:has-text('Buy now')"
  }
}